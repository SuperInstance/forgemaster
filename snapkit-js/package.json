{
  "name": "@superinstance/snapkit",
  "version": "1.0.0",
  "description": "Eisenstein lattice snap, temporal beat alignment, and spectral analysis — zero dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "npx tsx tests/index.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "eisenstein",
    "lattice",
    "snap",
    "voronoi",
    "temporal",
    "spectral",
    "hurst",
    "autocorrelation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/snapkit-js"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0"
  },
  "peerDependencies": {},
  "dependencies": {}
}
